# ============================================
# CREATORLAUNCH AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# SENTRY CONFIGURATION (Error Monitoring)
# ============================================
# Get DSN from: https://sentry.io/settings/projects/your-project/keys/
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
VITE_SENTRY_ENVIRONMENT=production
# Options: development, staging, production

# ============================================
# POSTHOG CONFIGURATION (Analytics)
# ============================================
# Get from: https://posthog.com/project/settings
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com
# Use https://eu.posthog.com for EU hosting

# ============================================
# APPLICATION SETTINGS
# ============================================
VITE_APP_NAME=CreatorLaunch AI
VITE_APP_URL=https://your-domain.com
VITE_APP_ENV=production
# Options: development, production

# ============================================
# AI API KEYS (Set in Supabase Edge Functions)
# ============================================
# These should be set as Supabase secrets, not in .env:
# npx supabase secrets set OPENAI_API_KEY=sk-xxxxx
# npx supabase secrets set GROK_API_KEY=your_grok_key

# OPENAI_API_KEY=sk-xxxxx  # Do NOT commit this!
# GROK_API_KEY=xxxxx        # Do NOT commit this!

# ============================================
# OPTIONAL: PAYMENT GATEWAY (Future)
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ============================================
# NOTES:
# ============================================
# 1. Never commit .env file to git (already in .gitignore)
# 2. Keep API keys secure and rotate them regularly
# 3. Use different keys for dev/staging/production
# 4. AI API keys should be set in Supabase Edge Functions
# 5. For local dev, use npx supabase start for local Supabase
